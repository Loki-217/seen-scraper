/* 布局样式 */

/* Header */
.header {
    background: var(--brand-gradient);
    color: white;
    padding: 1rem 2rem;
    display: flex;
    align-items: center;
    gap: 1rem;
    box-shadow: var(--shadow-md);
    flex-shrink: 0;
    z-index: 100;
    height: 70px; /* 🔥 固定高度 */
}

.brand-logo {
    display: flex;
    align-items: center;
    gap: 0.75rem;
}

.brand-icon {
    width: 36px;
    height: 36px;
    background: white;
    border-radius: var(--border-radius-md);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 20px;
}

.brand-name {
    font-size: 1.5rem;
    font-weight: 700;
}

.brand-tagline {
    font-size: 0.9rem;
    opacity: 0.9;
    margin-left: 1rem;
    padding-left: 1rem;
    border-left: 2px solid rgba(255,255,255,0.3);
}

/* URL 容器 */
.url-container {
    flex: 1;
    display: flex;
    gap: 0.5rem;
    align-items: center;
}

.url-input {
    flex: 1;
    padding: 0.75rem 1rem;
    border: none;
    border-radius: var(--border-radius-md);
    font-size: 1rem;
    background: white;
}

/* 🔥 主容器 - 修复高度 */
.main-wrapper {
    flex: 1;
    display: flex;
    overflow: hidden;
    height: calc(100vh - 70px); /* 减去 header 高度 */
}

/* 左侧工具栏 */
.left-sidebar {
    width: 60px;
    background: #2c3e50;
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 1rem 0;
    gap: 1rem;
    box-shadow: var(--shadow-md);
    flex-shrink: 0; /* 🔥 防止收缩 */
}

.sidebar-icon {
    width: 40px;
    height: 40px;
    background: rgba(255,255,255,0.1);
    border-radius: var(--border-radius-md);
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    font-size: 1.2rem;
    cursor: pointer;
    transition: all var(--transition-base);
}

.sidebar-icon:hover {
    background: rgba(255,255,255,0.2);
    transform: scale(1.1);
}

/* 🔥 中间内容区 - 修复布局 */
.content-area {
    flex: 1;
    display: flex;
    flex-direction: column;
    overflow: hidden;
    min-width: 0; /* 防止内容溢出 */
}

/* 🔥 预览区域 - 固定高度比例 */
.preview-area {
    flex: 1;
    min-height: 0; /* 🔥 关键：允许 flex 子元素收缩 */
    position: relative;
    background: white;
    margin: 1rem 1rem 0.5rem 1rem; /* 减小底部 margin */
    border-radius: var(--border-radius-lg);
    box-shadow: var(--shadow-md);
    overflow: hidden;
}

.preview-iframe {
    width: 100%;
    height: 100%;
    border: none;
}

/* 智能模式面板 */
.smart-panel {
    width: 100%;
    height: 100%;
    background: white;
    padding: 2rem;
    overflow-y: auto;
}

/* 🔥 底部数据预览 - 固定高度 */
.data-preview-area {
    height: 250px; /* 固定高度 */
    flex-shrink: 0; /* 🔥 防止被挤压 */
    background: white;
    margin: 0.5rem 1rem 1rem 1rem;
    border-radius: var(--border-radius-lg);
    box-shadow: var(--shadow-md);
    padding: 1rem;
    display: flex;
    flex-direction: column;
}

.preview-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1rem;
    padding-bottom: 0.75rem;
    border-bottom: 2px solid var(--border-color);
    flex-shrink: 0; /* 防止被挤压 */
}

.preview-table-container {
    flex: 1;
    overflow: auto;
    min-height: 0; /* 允许滚动 */
}

/* 配置按钮 */
.config-toggle-btn {
    position: fixed;
    top: 120px;
    right: 20px;
    width: 60px;
    height: 60px;
    background: var(--brand-success);
    color: white;
    border: none;
    border-radius: 50%;
    font-size: 1.5rem;
    cursor: pointer;
    box-shadow: var(--shadow-xl);
    z-index: 1000;
    transition: all var(--transition-base);
}

.config-toggle-btn:hover {
    transform: scale(1.1);
}

/* 配置弹窗 */
.config-modal {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: rgba(0,0,0,0.5);
    display: none;
    align-items: center;
    justify-content: center;
    z-index: 2000;
}

.config-modal.active {
    display: flex;
}

.config-content {
    background: var(--brand-success);
    width: 90%;
    max-width: 500px;
    max-height: 80vh;
    border-radius: var(--border-radius-lg);
    box-shadow: var(--shadow-xl);
    display: flex;
    flex-direction: column;
}

.config-header {
    background: rgba(0,0,0,0.1);
    padding: 1.25rem 1.5rem;
    border-radius: var(--border-radius-lg) var(--border-radius-lg) 0 0;
    display: flex;
    justify-content: space-between;
    align-items: center;
    color: white;
}

.config-body {
    flex: 1;
    overflow-y: auto;
    padding: 1.5rem;
    color: white;
}

.config-footer {
    padding: 1rem 1.5rem;
    border-top: 1px solid rgba(255,255,255,0.2);
    display: flex;
    gap: 0.5rem;
}

/* 🔥 响应式 */
@media (max-width: 768px) {
    .left-sidebar {
        width: 50px;
    }
    
    .brand-tagline {
        display: none;
    }
    
    .data-preview-area {
        height: 200px;
    }
    
    .preview-area {
        margin: 0.5rem;
    }
}

/* 🔥 大屏优化 */
@media (min-width: 1920px) {
    .data-preview-area {
        height: 300px;
    }
}